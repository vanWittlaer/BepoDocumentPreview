<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true" public="false"/>

        <prototype namespace="Bepo\DocumentPreview\" resource="../../*">
            <exclude>../../BepoDocumentPreview.php</exclude>
        </prototype>

        <service id="Bepo\DocumentPreview\Controller\DocumentPreviewController" public="true">
            <argument key="$projectDir">%kernel.project_dir%</argument>
        </service>
    </services>
</container>
